{
  "name": "eodhd_full_walk_forward",
  "description": "Standard full V1 classification profile sourced from the full EODHD panel. It materializes a high-liquidity panel first and trains only the selected classifier candidates from model selection: sequence classifier with sentiment sequence inputs, torch MLP classifier with tabular fundamentals/sentiment/context inputs, and XGBoost classifier with the same tabular inputs. Regression is intentionally disabled.",
  "dataset_root": "data/eodhd_us_equities_30y",
  "stages": [
    "materialize_panel",
    "materialize_cache",
    "train"
  ],
  "build_features": {
    "force": false,
    "max_tickers": 0,
    "progress_every": 250,
    "resume": true,
    "skip_fundamentals": false,
    "skip_sentiment": false
  },
  "materialize_panel": {
    "end_date": "2026-04-24",
    "force": true,
    "max_tickers": 1500,
    "min_latest_dollar_volume": 1000000,
    "min_latest_price": 1,
    "output_dataset_root": "data/eodhd_training_panels/eodhd_full_walk_forward",
    "progress_every": 1000000,
    "start_date": "2014-01-01",
    "ticker_selection": "latest_dollar_volume"
  },
  "materialize_cache": {
    "cache_dir": "data/eodhd_training_panels/eodhd_full_walk_forward/episode_cache",
    "force": true,
    "progress_every": 250
  },
  "train": {
    "benchmark_ticker": "SPY",
    "classification_horizon": 20,
    "classification_models": [
      "torch_seq_static_classifier",
      "torch_mlp_classifier",
      "xgboost_classifier"
    ],
    "classification_threshold": 0.05,
    "eval_mode": "walk_forward",
    "feature_sets": [
      "stock_relative_market_sector_fundamentals_sentiment",
      "stock_relative_market_sector_sentiment_sequence"
    ],
    "final_stop_block_size": 21,
    "horizons": [
      5,
      10,
      20
    ],
    "output_root": "artifacts/v1_baselines",
    "run_name": "eodhd_full_walk_forward",
    "task_type": "classification",
    "max_episodes": 500000,
    "torch_batch_size": 1024,
    "torch_max_epochs": 20,
    "torch_patience": 4,
    "walk_forward_max_folds": 6,
    "walk_forward_min_train_dates": 252,
    "walk_forward_oos_block_size": 21,
    "walk_forward_purge_gap": 20,
    "walk_forward_val_block_size": 21,
    "window_length": 60
  }
}
