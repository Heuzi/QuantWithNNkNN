{
  "name": "eodhd_true_full_torch_mlp",
  "description": "Model-specific true full-universe run for the selected tabular Torch MLP classifier. Uses the existing uncapped 32M-episode cache and trains only torch_mlp_classifier on the selected tabular feature set.",
  "dataset_root": "data/eodhd_us_equities_30y",
  "training_dataset_root": "data/eodhd_training_panels/eodhd_true_full_walk_forward",
  "episode_cache_dir": "data/eodhd_training_panels/eodhd_true_full_walk_forward/episode_cache",
  "stages": [
    "train"
  ],
  "train": {
    "benchmark_ticker": "SPY",
    "classification_horizon": 20,
    "classification_models": [
      "torch_mlp_classifier"
    ],
    "classification_threshold": 0.05,
    "eval_mode": "walk_forward",
    "feature_sets": [
      "stock_relative_market_sector_fundamentals_sentiment"
    ],
    "final_stop_block_size": 21,
    "horizons": [
      5,
      10,
      20
    ],
    "max_episodes": 0,
    "output_root": "artifacts/v1_baselines",
    "run_name": "eodhd_true_full_torch_mlp",
    "task_type": "classification",
    "torch_batch_size": 8192,
    "torch_max_epochs": 20,
    "torch_patience": 4,
    "walk_forward_max_folds": 6,
    "walk_forward_min_train_dates": 252,
    "walk_forward_oos_block_size": 21,
    "walk_forward_purge_gap": 20,
    "walk_forward_val_block_size": 21,
    "window_length": 60
  }
}
