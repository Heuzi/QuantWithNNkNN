{
  "name": "eodhd_true_full_walk_forward",
  "description": "True full-universe V1 classification run under the filtered strategy universe. This rebuilds the uncapped panel and episode cache with path_5pct_20d plus the shared conservative research-universe policy before training the three supported production classifiers.",
  "dataset_root": "data/eodhd_us_equities_30y",
  "stages": [
    "materialize_panel",
    "materialize_cache",
    "train"
  ],
  "build_features": {
    "force": false,
    "max_tickers": 0,
    "progress_every": 250,
    "resume": true,
    "skip_fundamentals": false,
    "skip_sentiment": false
  },
  "materialize_panel": {
    "end_date": "2026-05-08",
    "force": true,
    "max_tickers": 0,
    "output_dataset_root": "C:/QuantWithNNkNN_fast/data/eodhd_training_panels/eodhd_true_full_walk_forward",
    "progress_every": 1000000,
    "start_date": "1995-01-01",
    "ticker_selection": "first"
  },
  "materialize_cache": {
    "cache_dir": "C:/QuantWithNNkNN_fast/data/eodhd_training_panels/eodhd_true_full_walk_forward/episode_cache",
