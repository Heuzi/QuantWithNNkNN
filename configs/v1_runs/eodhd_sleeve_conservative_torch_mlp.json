{
  "name": "eodhd_sleeve_conservative_torch_mlp",
  "description": "Train/test the conservative sleeve Torch MLP classifier independently from all other sleeves.",
  "dataset_root": "data/eodhd_us_equities_30y",
  "training_dataset_root": "data/eodhd_training_panels/eodhd_sleeve_conservative",
  "episode_cache_dir": "data/eodhd_training_panels/eodhd_sleeve_conservative/episode_cache",
  "stages": [
    "train"
  ],
  "train": {
    "benchmark_ticker": "SPY",
