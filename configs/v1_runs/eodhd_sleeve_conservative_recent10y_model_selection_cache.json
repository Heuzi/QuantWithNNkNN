{
  "name": "eodhd_sleeve_conservative_recent10y_model_selection_cache",
  "description": "Materialize a recent-10-year conservative sleeve panel and shared model-selection episode cache with tabular and sequence feature sets.",
  "dataset_root": "data/eodhd_us_equities_30y",
  "stages": [
    "materialize_panel",
    "materialize_cache"
  ],
  "materialize_panel": {
    "force": true,
    "max_tickers": 0,
    "output_dataset_root": "data/eodhd_training_panels/eodhd_sleeve_conservative_recent10y",
    "progress_every": 1000000,
    "start_date": "2016-06-08",
    "ticker_selection": "first"
  },
  "materialize_cache": {
    "cache_dir": "data/eodhd_training_panels/eodhd_sleeve_conservative_recent10y/episode_cache_model_selection",
    "force": true,
    "max_episodes_per_anchor_date": 120,
    "progress_every": 250
  },
  "train": {
    "benchmark_ticker": "SPY",
    "classification_event_type": "path_5pct_20d",
    "classification_horizon": 20,
    "classification_threshold": 0.05,
    "eval_mode": "walk_forward",
    "feature_sets": [
      "stock_only_fundamentals",
      "stock_only_sentiment",
      "stock_only_fundamentals_sentiment",
      "stock_relative_market_sector_fundamentals_sentiment",
      "stock_normalized_lean_market_sector_fundamentals_sentiment",
      "stock_only_sequence"
    ],
    "horizons": [
      5,
      10,
      20
    ],
    "task_type": "classification",
    "walk_forward_anchor_last_oos": true,
    "walk_forward_max_folds": 1,
    "walk_forward_min_train_dates": 252,
    "walk_forward_oos_block_size": 20,
    "walk_forward_purge_gap": 20,
    "walk_forward_val_block_size": 20,
    "window_length": 60,
    "research_universe_name": "conservative",
    "research_allowed_exchanges": "NYSE,NASDAQ,AMEX",
    "research_min_price": 10.0,
    "research_min_history_days": 252,
    "research_min_median_dollar_volume_20d": 10000000.0,
    "research_min_median_dollar_volume_60d": 10000000.0,
    "research_max_zero_volume_day_ratio_60d": 0.02,
    "research_min_current_dollar_volume_vs_median_20d": 0.2,
    "research_liquidity_short_lookback_days": 20,
    "research_liquidity_long_lookback_days": 60,
    "research_trend_lookback_days": 252,
    "research_return_6m_lookback_days": 126,
    "research_sma_short_lookback_days": 50,
    "research_sma_long_lookback_days": 200,
    "research_min_return_6m": -0.15,
    "research_max_drawdown_from_252d_high_pct": 35.0,
    "research_spike_lookback_days": 60,
    "research_max_abs_return_1d_60d_pct": 25.0,
    "research_max_true_range_60d_pct": 25.0
  }
}
